# Database (SQLite for dev, change to postgresql://... for production)
DATABASE_URL="file:./dev.db"

# NextAuth — generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Platform rake (fraction of each bet → admin account for server costs)
# 0.02 = 2% ≈ 3 tokens/month at ~150 tokens staked/month
NEXT_PUBLIC_RAKE_PERCENT="0.02"

# Optional: require invite code on registration
# INVITE_CODE="your-invite-code"

# Optional: Stripe (stub is ready, just add keys to activate)
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
