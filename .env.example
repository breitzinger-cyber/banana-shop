# ─────────────────────────────────────────────────────────────
#  Banana Shop — environment variables
#  Copy to .env and fill in. NEVER commit .env.
# ─────────────────────────────────────────────────────────────

# Database — PostgreSQL (Neon, Supabase, Railway, etc.)
# DATABASE_URL: the POOLED connection string (host contains "-pooler").
#   Used by the app at runtime.
# DIRECT_URL:   the DIRECT (non-pooled) connection string.
#   Used only for running migrations. On Neon, copy both from the
#   dashboard's "Connection string" panel (toggle the pooler switch).
DATABASE_URL="postgresql://user:password@host-pooler/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# NextAuth — generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
# In production set this to your real domain, e.g. https://banana-shop.vercel.app
NEXTAUTH_URL="http://localhost:3000"

# Platform rake (fraction of each bet → admin account for server costs)
# 0.02 = 2%
NEXT_PUBLIC_RAKE_PERCENT="0.02"

# Optional: require an invite code on registration
# INVITE_CODE="your-invite-code"

# ── Web Push (VAPID) — optional, for browser notifications ──
# Generate a key pair with: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY="..."
# VAPID_PRIVATE_KEY="..."
# NEXT_PUBLIC_VAPID_PUBLIC_KEY="..."   # same value as VAPID_PUBLIC_KEY

# ── Stripe — optional, enables buying tokens (1 token = €1) ──
# Without these, the "Buy Tokens" button shows a friendly notice.
# STRIPE_SECRET_KEY="sk_live_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."          # from the Stripe webhook endpoint
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_..."
